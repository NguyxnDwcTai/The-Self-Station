generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  categoryID   String     @id @db.VarChar(50)
  categoryName String     @db.VarChar(255)
  description  String?    @db.VarChar(255)
  
  menuItems    MenuItem[]
}

model Promotion {
  promoID       String      @id @db.VarChar(50)
  promoName     String      @db.VarChar(255)
  discountType  Int
  discountValue Decimal     @db.Decimal(18, 2)
  applyScore    Int?
  startDate     DateTime    @db.Timestamp(0)
  endDate       DateTime    @db.Timestamp(0)
  
  promoItems    PromoItem[]
  orders        Orders[]
}

model Account {
  accountID    String   @id @db.VarChar(50)
  username     String   @unique @db.VarChar(100)
  passwordHash String   @db.VarChar(255)
  role         Int
  isActive     Boolean? @default(true) @db.Bit(1)
  branchID     String   @db.VarChar(50)

  branch       Branch   @relation(fields: [branchID], references: [branchID])
  orders       Orders[]
}

model Customer {
  customerID   String   @id @db.VarChar(50)
  fullName     String   @db.VarChar(255)
  phone        String   @unique @db.VarChar(20)
  rewardPoints Int?     @default(0)
  
  orders       Orders[]
}

model DiningTable {
  tableID   String   @id @db.VarChar(50)
  tableName String   @db.VarChar(100)
  status    Int?     @default(0)
  branchID  String   @db.VarChar(50)

  branch    Branch   @relation(fields: [branchID], references: [branchID])
  orders    Orders[]
}

model Voucher {
  voucherID        String    @id @db.VarChar(50)
  voucherCode      String    @unique @db.VarChar(50)
  discountType     Int
  discountValue    Decimal   @db.Decimal(18, 2)
  minTotalRequired Decimal?  @default(0) @db.Decimal(18, 2)
  usageLimit       Int?
  usedCount        Int?      @default(0)
  startDate        DateTime  @db.Timestamp(0)
  expiryDate       DateTime  @db.Timestamp(0)
  isActive         Boolean?  @default(true) @db.Bit(1)
  
  orders           Orders[]
}

model MenuItem {
  itemID       String        @id @db.VarChar(50)
  categoryID   String        @db.VarChar(50)
  itemName     String        @db.VarChar(255)
  price        Decimal       @db.Decimal(18, 2)
  imageURL     String?       @db.VarChar(255)
  isActive     Boolean?      @default(true) @db.Bit(1)
  
  category     Category      @relation(fields: [categoryID], references: [categoryID])
  promoItems   PromoItem[]
  orderDetails OrderDetail[]
}

model Orders {
  orderID     String    @id @db.VarChar(50)
  tableID     String    @db.VarChar(50)
  promoID     String?   @db.VarChar(50)
  cashierID   String?   @db.VarChar(50)
  customerID  String?   @db.VarChar(50)
  voucherID   String?   @db.VarChar(50)
  status      Int?      @default(0)
  totalAmount Decimal?  @default(0) @db.Decimal(18, 2)
  orderDate   DateTime? @default(now()) @db.Timestamp(0)
  branchID    String    @db.VarChar(50)

  table        DiningTable   @relation(fields: [tableID], references: [tableID])
  promotion    Promotion?    @relation(fields: [promoID], references: [promoID])
  cashier      Account?      @relation(fields: [cashierID], references: [accountID])
  customer     Customer?     @relation(fields: [customerID], references: [customerID])
  voucher      Voucher?      @relation(fields: [voucherID], references: [voucherID])
  branch       Branch        @relation(fields: [branchID], references: [branchID])
  orderDetails OrderDetail[]
}

model PromoItem {
  promoID   String    @db.VarChar(50)
  itemID    String    @db.VarChar(50)
  
  promotion Promotion @relation(fields: [promoID], references: [promoID])
  menuItem  MenuItem  @relation(fields: [itemID], references: [itemID])

  @@id([promoID, itemID])
}

model OrderDetail {
  orderID    String   @db.VarChar(50)
  itemID     String   @db.VarChar(50)
  quantity   Int
  unitPrice  Decimal  @db.Decimal(18, 2)
  cookStatus Int?     @default(0)

  order      Orders   @relation(fields: [orderID], references: [orderID])
  menuItem   MenuItem @relation(fields: [itemID], references: [itemID])

  @@id([orderID, itemID])
}

model Branch {
  branchID   String   @id @db.VarChar(50)
  branchName String   @db.VarChar(255)
  address    String   @db.VarChar(255)
  hotline    String   @db.VarChar(20)
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  openTime   DateTime @db.Time(0)
  closeTime  DateTime @db.Time(0)
  isActive   Boolean? @default(true) @db.Bit(1)

  accounts   Account[]
  tables     DiningTable[]
  orders     Orders[]
}
